# ==============================================================================
# Agentic ERP Supply Chain Copilot — Environment Variables
# Copy this file to .env and fill in real values.
# The .env file is gitignored — NEVER commit secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# GitHub Models API (primary LLM)
# Endpoint: https://models.inference.ai.azure.com
# Get a Fine-Grained PAT at https://github.com/settings/tokens
# Required scopes: (none — model access is tied to your GitHub account)
# ------------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_github_pat_here

# ------------------------------------------------------------------------------
# PostgreSQL (AdventureWorks + pgvector)
# Matches docker/docker-compose.yml POSTGRES_PASSWORD
# ------------------------------------------------------------------------------
PG_PASSWORD=changeme_use_strong_password

# ------------------------------------------------------------------------------
# Neo4j (Knowledge Graph)
# Matches docker/docker-compose.yml NEO4J_AUTH password component
# ------------------------------------------------------------------------------
NEO4J_PASSWORD=changeme_use_strong_password

# ------------------------------------------------------------------------------
# LangSmith (LLM tracing — optional for local dev, required for Stage 5 eval)
# Sign up at https://smith.langchain.com
# ------------------------------------------------------------------------------
LANGSMITH_API_KEY=lsv2_your_langsmith_key_here
LANGCHAIN_PROJECT=agentic-erp-supply-chain
LANGCHAIN_TRACING_V2=false

# ------------------------------------------------------------------------------
# JWT (backend authentication)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=changeme_replace_with_64_char_hex

# ==============================================================================
# Stage 7 (Project 2 CI/CD) — NOT needed for local development
# These are set as GitHub Actions secrets in Agentic-ERP-SupplyChain-Copilot
# ==============================================================================

# AZURE_CREDENTIALS={"clientId":"...","clientSecret":"...","subscriptionId":"...","tenantId":"..."}
# ACR_NAME=your_acr_registry_name
# DEPLOY_REPO_PAT=github_fine_grained_pat_with_contents_write_on_Agentic-ERP-Deploy
